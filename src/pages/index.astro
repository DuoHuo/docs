---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { categories, siteConfig } from "../lib/site";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recent = posts.slice(0, 4);
const countByCat: Record<string, number> = {};
for (const p of posts) {
  const cat = p.id.split("/")[0];
  countByCat[cat] = (countByCat[cat] || 0) + 1;
}
const labelOf = (slug: string) => categories.find((c) => c.slug === slug)?.label;
---

<BaseLayout sideBarActiveItemID="home">
  <section class="pb-2">
    <h1 class="text-3xl font-bold tracking-tight">{siteConfig.name}</h1>
    <p class="mt-2 max-w-prose text-muted-foreground">
      {siteConfig.role}的技术积累与知识库。分门别类，供历届社友学习参考。
    </p>
  </section>

  <h2 class="mb-3 mt-8 text-lg font-semibold text-muted-foreground">栏目</h2>
  <div class="grid gap-3 sm:grid-cols-2">
    {
      categories.map((c) => (
        <a
          href={`/blog/${c.slug}`}
          class="group rounded-lg border bg-card p-4 transition-all hover:border-primary/40 hover:shadow-md"
        >
          <div class="flex items-center justify-between">
            <div class="font-semibold group-hover:underline">{c.label}</div>
            <span class="text-xs text-muted-foreground">{countByCat[c.slug] || 0} 篇</span>
          </div>
          <p class="mt-1 text-sm text-muted-foreground">{c.description}</p>
        </a>
      ))
    }
  </div>

  <h2 class="mb-3 mt-10 text-lg font-semibold text-muted-foreground">最近文章</h2>
  <div class="flex flex-col gap-3">
    {
      recent.map((post) => {
        const cat = post.id.split("/")[0];
        return (
          <HorizontalCard
            title={post.data.title}
            desc={post.data.description}
            url={`/blog/${post.id}`}
            pubDate={post.data.pubDate}
            author={post.data.author}
            category={cat}
            categoryLabel={labelOf(cat)}
            tags={post.data.tags}
          />
        );
      })
    }
  </div>
</BaseLayout>
