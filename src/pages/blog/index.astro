---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalCard from "../../components/HorizontalCard.astro";
import { categories } from "../../lib/site";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const labelOf = (slug: string) => categories.find((c) => c.slug === slug)?.label;
---

<BaseLayout title={`全部文章 - 多火知识库`} sideBarActiveItemID="blog">
  <h1 class="mb-4 text-2xl font-bold tracking-tight">全部文章</h1>
  {
    posts.length === 0 ? (
      <div class="rounded-md border bg-muted p-6 text-center text-sm text-muted-foreground">
        还没有文章。
      </div>
    ) : (
      <div class="flex flex-col gap-3">
        {posts.map((post) => {
          const cat = post.id.split("/")[0];
          return (
            <HorizontalCard
              title={post.data.title}
              desc={post.data.description}
              url={`/blog/${post.id}`}
              pubDate={post.data.pubDate}
              author={post.data.author}
              category={cat}
              categoryLabel={labelOf(cat)}
              tags={post.data.tags}
            />
          );
        })}
      </div>
    )
  }
</BaseLayout>
