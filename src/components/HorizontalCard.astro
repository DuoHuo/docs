---
import { Image } from "astro:assets";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";

dayjs.extend(localizedFormat);

const {
  title,
  img,
  desc,
  url,
  badge,
  tags = [],
  category,
  categoryLabel,
  pubDate,
  author,
  target = "_self",
} = Astro.props;
---

<div class="group rounded-lg border bg-card p-4 transition-all hover:shadow-md">
  <a href={url} target={target} class="flex flex-col gap-4 md:flex-row">
    {
      img && (
        <Image
          src={img}
          width={750}
          height={422}
          format="webp"
          alt={title}
          class="w-full rounded-md object-cover md:w-52"
        />
      )
    }
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-2">
        {
          category && categoryLabel && (
            <span class="inline-flex items-center rounded-full bg-primary/10 px-2 py-0.5 text-xs font-medium text-foreground">
              {categoryLabel}
            </span>
          )
        }
        <h2 class="text-lg font-semibold leading-tight group-hover:underline">{title}</h2>
        {
          badge && (
            <span class="inline-flex items-center rounded-full border border-transparent bg-secondary text-secondary-foreground px-2 py-0.5 text-xs font-medium">
              {badge}
            </span>
          )
        }
      </div>
      <p class="mt-2 text-sm text-muted-foreground">{desc}</p>
      <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-muted-foreground">
        {pubDate && <time>{dayjs(pubDate).format("ll")}</time>}
        {author && <span>· {author}</span>}
      </div>
    </div>
  </a>
  {
    tags && tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="inline-flex items-center rounded-full border border-input px-2 py-0.5 text-xs text-muted-foreground">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</div>
